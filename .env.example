# =============================================================================
# Banco de Dados (Vercel Postgres)
# Obtenha em: Vercel Dashboard > Storage > Create Database > Postgres
# =============================================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# =============================================================================
# Firebase (Autenticação)
# Obtenha em: Firebase Console > Configurações do Projeto
# =============================================================================

# Cliente (exposto ao browser - prefixo NEXT_PUBLIC_ obrigatório)
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSy..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="seu-projeto.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="seu-projeto"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="seu-projeto.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789:web:abc123"

# Servidor / Admin SDK (obtenha em: Firebase Console > Configurações > Contas de serviço)
FIREBASE_ADMIN_PROJECT_ID="seu-projeto"
FIREBASE_ADMIN_CLIENT_EMAIL="firebase-adminsdk-xxx@seu-projeto.iam.gserviceaccount.com"
# A chave privada JSON em base64: openssl base64 -in privateKey.json | tr -d '\n'
FIREBASE_ADMIN_PRIVATE_KEY_BASE64="LS0tLS1CRUdJTiBSU0EgUFJJVkFURSBLRVktLS0tLQ=="

# =============================================================================
# Sentry (Monitoramento de Erros)
# Obtenha em: sentry.io > Settings > Projects > Client Keys (DSN)
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN="https://abc123@o123456.ingest.sentry.io/123456"
SENTRY_ORG="sua-organizacao"
SENTRY_PROJECT="stock-beauty-clinic"
# Obtenha em: sentry.io > Settings > Account > API > Auth Tokens
SENTRY_AUTH_TOKEN="sntrys_..."

# =============================================================================
# Aplicação
# =============================================================================
NEXT_PUBLIC_APP_URL="https://seu-dominio.vercel.app"
# Ambiente: development | production
NODE_ENV="production"
