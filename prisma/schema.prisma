generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  clinico
}

enum CategoriaSaida {
  uso
  descarte
  ajuste
}

enum StatusPedido {
  pendente
  recebido
  cancelado
}

model TipoSaida {
  id        String         @id @default(cuid())
  nome      String
  slug      String         @unique
  categoria CategoriaSaida
  cor       String         @default("blue")
  ativo     Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  saidas    SaidaInsumo[]

  @@index([slug])
  @@index([categoria])
  @@map("tipo_saida")
}

model TipoInsumo {
  id        String   @id @default(cuid())
  nome      String
  slug      String   @unique
  cor       String   @default("gray")
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  insumos   Insumo[]

  @@index([slug])
  @@map("tipo_insumo")
}

model Unidade {
  id        String   @id @default(cuid())
  nome      String
  endereco  String?
  telefone  String?
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios User[]
  insumos  Insumo[]
  saidas   SaidaInsumo[]
  pedidos  Pedido[]
}

model User {
  id          String    @id @default(cuid())
  firebaseUid String    @unique
  email       String    @unique
  name        String
  role        UserRole  @default(clinico)
  ativo       Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  unidades    Unidade[]
  saidas      SaidaInsumo[]
  auditLogs   AuditLog[]
  pedidos     Pedido[]

  @@index([email])
  @@index([firebaseUid])
}

model Insumo {
  id               String     @id @default(cuid())
  nome             String
  lote             String
  tipoId           String
  tipoInsumo       TipoInsumo @relation(fields: [tipoId], references: [id])
  fornecedor       String
  quantidade       Int
  quantidadeMinima Int
  precoUnitario    Decimal?   @db.Decimal(10, 2)
  dataEntrada      DateTime
  dataVencimento   DateTime
  unidadeId        String
  unidade          Unidade    @relation(fields: [unidadeId], references: [id], onDelete: Restrict)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  saidas           SaidaInsumo[]

  @@index([tipoId])
  @@index([dataVencimento])
  @@index([unidadeId])
  @@index([fornecedor])
  @@index([nome])
  @@index([dataEntrada])
}

model SaidaInsumo {
  id           String    @id @default(cuid())
  insumoId     String
  insumo       Insumo    @relation(fields: [insumoId], references: [id], onDelete: Restrict)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  unidadeId    String
  unidade      Unidade   @relation(fields: [unidadeId], references: [id], onDelete: Restrict)
  quantidade   Int
  tipoSaidaId  String
  tipoSaida    TipoSaida @relation(fields: [tipoSaidaId], references: [id], onDelete: Restrict)
  motivo       String?
  observacao   String?
  dataRetirada DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([insumoId])
  @@index([userId])
  @@index([dataRetirada])
  @@index([tipoSaidaId])
  @@index([unidadeId])
}

model Pedido {
  id              String       @id @default(cuid())
  fornecedor      String
  produto         String
  quantidade      Int
  status          StatusPedido @default(pendente)
  observacao      String?
  dataPedido      DateTime     @default(now())
  dataPrevista    DateTime?
  dataRecebimento DateTime?
  unidadeId       String
  unidade         Unidade      @relation(fields: [unidadeId], references: [id], onDelete: Restrict)
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([unidadeId])
  @@index([userId])
  @@index([status])
  @@index([fornecedor])
  @@index([dataPedido])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  action    String
  entity    String
  entityId  String
  details   Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}