generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  clinico
}

enum TipoInsumo {
  injetavel
  descartavel
  peeling
}

enum TipoSaida {
  uso
  descarte
  ajuste
}

model Unidade {
  id        String   @id @default(cuid())
  nome      String
  endereco  String?
  telefone  String?
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios User[]
  insumos  Insumo[]
  saidas   SaidaInsumo[]
}

model User {
  id          String    @id @default(cuid())
  firebaseUid String    @unique
  email       String    @unique
  name        String
  role        UserRole  @default(clinico)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  unidades    Unidade[]
  saidas      SaidaInsumo[]

  @@index([email])
  @@index([firebaseUid])
}

model Insumo {
  id               String     @id @default(cuid())
  nome             String
  lote             String
  tipo             TipoInsumo
  fornecedor       String
  quantidade       Int
  quantidadeMinima Int
  dataEntrada      DateTime
  dataVencimento   DateTime
  unidadeId        String
  unidade          Unidade    @relation(fields: [unidadeId], references: [id], onDelete: Restrict)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  saidas           SaidaInsumo[]

  @@index([tipo])
  @@index([dataVencimento])
  @@index([unidadeId])
}

model SaidaInsumo {
  id           String    @id @default(cuid())
  insumoId     String
  insumo       Insumo    @relation(fields: [insumoId], references: [id], onDelete: Restrict)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  unidadeId    String
  unidade      Unidade   @relation(fields: [unidadeId], references: [id], onDelete: Restrict)
  quantidade   Int
  tipo         TipoSaida @default(uso)
  motivo       String?
  observacao   String?
  dataRetirada DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([insumoId])
  @@index([userId])
  @@index([dataRetirada])
  @@index([tipo])
  @@index([unidadeId])
}
